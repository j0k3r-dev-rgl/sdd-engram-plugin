{
	"name": "opencode-sdd-engram-manage",
	"version": "1.6.8",
	"description": "Interactive SDD model selection and profile management for opencode",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/j0k3r-dev-rgl/sdd-engram-plugin.git"
	},
	"bugs": {
		"url": "https://github.com/j0k3r-dev-rgl/sdd-engram-plugin/issues"
	},
	"homepage": "https://github.com/j0k3r-dev-rgl/sdd-engram-plugin#readme",
	"license": "MIT",
	"type": "module",
	"main": "./dist/tui.js",
	"exports": {
		"./tui": {
			"import": "./dist/tui.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"prepack": "npm run build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:fallback": "node ./scripts/test-fallback.ts",
		"examples": "node ./scripts/run-examples.ts",
		"orchestrator:fallback:check": "node ./scripts/ensure-orchestrator-fallback-policy.ts --check",
		"orchestrator:fallback:apply": "node ./scripts/ensure-orchestrator-fallback-policy.ts",
		"semantic-release": "semantic-release"
	},
	"devDependencies": {
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/commit-analyzer": "13.0.1",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/github": "12.0.8",
		"@semantic-release/npm": "13.1.5",
		"@semantic-release/release-notes-generator": "14.1.1",
		"@types/node": "25.7.0",
		"@vitest/coverage-v8": "4.1.6",
		"esbuild-plugin-solid": "0.6.0",
		"semantic-release": "25.0.3",
		"typescript": "6.0.3",
		"tsup": "8.5.1",
		"vitest": "4.1.6"
	},
	"overrides": {
		"@babel/core": "7.29.7",
		"esbuild": "0.28.1",
		"js-yaml": "4.3.0",
		"npm": "11.18.0",
		"undici": "7.28.0",
		"vite": "8.1.0"
	},
	"peerDependencies": {
		"@opencode-ai/plugin": ">=1.17.11",
		"@opentui/core": ">=0.4.2 <1",
		"@opentui/keymap": ">=0.4.2 <1",
		"@opentui/solid": ">=0.4.2 <1",
		"solid-js": "1.9.12"
	},
	"engines": {
		"node": ">=24 <25",
		"opencode": ">=1.17.11"
	}
}
